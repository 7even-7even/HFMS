NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cure_cafe?schema=public"
JWT_ACCESS_SECRET="dev_access_secret_change_me_32_chars_minimum"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me_32_chars_minimum"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"
UPLOAD_DIR="uploads"
EMAIL_VERIFICATION_TTL_MINUTES=60

# Optional SMTP. If left empty in development, verification links are logged to the API console.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Cure Cafe <no-reply@curecafe.local>"
