# Root reference file. Copy apps/api/.env.example to apps/api/.env for API runtime.
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cure_cafe?schema=public"
JWT_ACCESS_SECRET="replace_with_a_long_random_access_secret"
JWT_REFRESH_SECRET="replace_with_a_long_random_refresh_secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"
UPLOAD_DIR="uploads"
EMAIL_VERIFICATION_TTL_MINUTES=60

# HTTP email provider: Brevo. If BREVO_API_KEY is empty in development,
# verification links are logged to the API console.
BREVO_API_KEY=""
EMAIL_FROM_NAME="Cure Cafe"
EMAIL_FROM_EMAIL="devloper7even@gmail.com"
